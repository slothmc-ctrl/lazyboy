{
	"$schema": "https://biomejs.dev/schemas/2.3.5/schema.json",
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true
		}
	},
	"formatter": {
		"enabled": true,
		"formatWithErrors": false,
		"indentStyle": "tab",
		"indentWidth": 3,
		"lineWidth": 120
	},
	"files": {
		"includes": [
			"src/**/*",
			"scripts/**/*",
			"*.json",
			"*.md",
			"!**/node_modules/**/*",
			"!**/*.css",
			"!!**/node_modules"
		]
	}
}
